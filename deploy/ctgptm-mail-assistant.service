[Unit]
Description=GPT Account Manager
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/ctgptm-mail-assistant
EnvironmentFile=/etc/ctgptm-mail-assistant.env
ExecStart=/usr/bin/python3 /opt/ctgptm-mail-assistant/server.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/ctgptm-mail-assistant/data /opt/ctgptm-mail-assistant/.cache

[Install]
WantedBy=multi-user.target
